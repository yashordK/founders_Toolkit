# Env vars read by scripts under agent/ and openclaw-skills/*/scripts/.
# Cognee's own configuration lives in the sibling cognee/ checkout's .env,
# not here -- see cognee/docker-compose.yml and this repo's README.

# Where the self-hosted Cognee instance is reachable.
COGNEE_BASE_URL=http://localhost:8000

# Dataset the skills read from and write to.
COGNEE_DATASET=founders_second_brain

# Used by agent/verify/verify_recall.mjs (the grounding check wired into
# warm-intro/daily-plan/nudge-sweep) to call an LLM directly, independent of
# Cognee. Point these at whatever LLM_* provider cognee/.env is currently
# configured for -- they are separate env vars because verify_recall.mjs
# calls the provider's chat completions endpoint directly rather than going
# through Cognee.
VERIFY_LLM_API_KEY=
VERIFY_LLM_MODEL=deepseek-r1-distill-llama-8b-abliterated
VERIFY_LLM_ENDPOINT=http://192.168.29.160:1234/v1
